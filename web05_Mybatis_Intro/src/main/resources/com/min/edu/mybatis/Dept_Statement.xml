<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<!-- 
	TODO 006 myBatis의 Mapper xml 파일 
	mapper는 myBatis에서 사용되는 쿼리문을 작성하는 곳
	CRUD 태그가 있고, 입력 Argument, 출력 객체(Primative, 객체(DTO, Map)), SQL문
-->

<!-- 
	namespace는 여러개의 mapper xml 파일 중에서 호출 하기 위한 값
	DAO/Repository의 위치를 이름으로 작성한다
-->
<mapper namespace="com.min.edu.detpRepository">
	
	<!-- 
		쿼리를 작성하는 곳
		id(호출을 고유한 값), parameterType(입력타입 - getter 자동 부름), resultType(출력타입 - setter 자동 부름)
	 -->
	<select id="selectAllEDept" resultType="com.min.edu.dto.DeptDto">
		<!-- 
			DEPTNO  -> resultType -> DeptDto -> setDeptno
			DNAME   -> resultType -> DeptDto -> setDname
			LOC		-> resultType -> DeptDto -> setLoc
		 -->
		SELECT DEPTNO, DANME, LOC
			FROM DEPT d
	</select>
	
	
</mapper>