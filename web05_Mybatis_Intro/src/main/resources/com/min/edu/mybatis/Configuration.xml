<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-config.dtd">
<!-- TODO 007 JDBC중 1단계 2단계 6단계를 처리해주는 공통모듈을 MyBatis의 환경설정의 값을 작성 -->
<configuration>
	<environments default="development">
		<environment id="development">
			<transactionManager type="JDBC" />
			<dataSource type="POOLED">
				<property name="driver"
					value="oracle.jdbc.driver.OracleDriver" />
				<property name="url"
					value="jdbc:oracle:thin@localhost:1521:xe" />
				<property name="username" value="EDU" />
				<property name="password" value="EDU" />
			</dataSource>
		</environment>
	</environments>

	<!-- TODO 008 사용할 쿼리의 묶음(Mapper)파일을 연결해 준다 -->
	<mappers>
		<mapper resource="com/min/edu/mybatis/Dept_Statement.xml" />
	</mappers>
</configuration>