<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.min.edu.repository.JobsIDURepositoryImpl">	<!-- 패키지명 아니고 그냥 아무 이름 써도 상관 없다 -->
	<!-- 
		insert, delete, update는 반환타입이 없다.
		reesultMap/resultType 속성이 없다.
		**** 성공한 row의 개수를 반환하기 때문에
			ex) insert 10줄을 입력 했다 => 10 정수값이 반환
	 -->
	<insert id="insert01" parameterType="JobsDto">	
		INSERT INTO JOBS (JOB_ID, JOB_TITLE, MIN_SALARY, MAX_SALARY)
			VALUES(#{job_id}, #{job_title}, #{min_salary}, #{max_salary})
	</insert>
	
	<!-- 
		Map을 통해서 전달(Parameter)
	 -->
	<delete id="delete01">
		DELETE FROM JOBS
			WHERE JOB_ID = #{id}
	</delete>
	
	<update id="update01">
		UPDATE JOBS SET JOB_TITLE = #{job_title}
		WHERE LOWER(JOB_ID) = LOWER(#{job_id})
	</update>
	
	
</mapper>