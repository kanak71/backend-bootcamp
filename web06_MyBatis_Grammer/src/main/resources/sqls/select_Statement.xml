<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.min.edu.repository.JobsSelectRepository">

	<!-- 반복되는 쿼리를 선언하여 중복코드를 쉽게 사용할 수 있도록 선언 sql, include를 통해서 사용 -->
	<sql id ="allColumn">
		SELECT JOB_ID, JOB_TITLE, MIN_SALARY, MAX_SALARY
 		FROM JOBS
	</sql>
	

	<!-- 
		컬럼명이 사용하는 DTO의 setter와 이름이 다른 경우 사용
		컬럼을 사용되는 DTO의 setter와 매핑을 통해서 값을 전달 할 수 있도록 한다
		column은 쿼리 결과의 컬럼명,
		property는 DTO의 set 메소드명 
			ex) JOB_ID => setJob_id
		ex) JOBID => setJob_id
		
			JOB_ID JOBID,
  			JOB_TITLE JOBTITLE,
  			MIN_SALARY MINSALARY,
  			MAX_SALARY MAXSALARY
	 -->

	<resultMap type="JobsDto" id="JobsToMap">
		<result column="JOBID" property="job_id"/>
		<result column="JOBTITLE" property="job_title"/>
		<result column="MINSALARY" property="min_salary"/>
		<result column="MAXSALARY" property="max_salary"/>
	
	</resultMap>

<!-- 
	전달되는 Parameter의 타입에 따라서 사용하는 방법이 다르다
	** MyBatis 3.x 부터는 Parameter를 명시적으로 작성하지 않아도 자동으로 처리해준다
		타입(Type)선언할때 참조 타입 : java.Lang.Integer => int혹은 Integer로만 사용해도 된다
	** Primitive Type의 경우 객체(담겨있는 DTO, Map)가 아니기 때문에 자동으로 값을 바인딩
		#{x}와 같이 변수명과는 상관 없이 값을 바인딩
	** 바인딩 문법
		${} -> 값 -> 값
		#{} -> 값 -> '값' => 입력된 값을 '으로 감싸서 처리한다
		
 -->
	<select id="select01" resultType="java.lang.Integer"
							parameterType="java.lang.String">
		SELECT MIN_SALARY
			FROM JOBS
			WHERE JOB_ID = #{x}
		
	</select>
	
<!-- 
	Parameter를 기본타입으로 전달, 결과를 Object(DTO)의 객체로 받는다
	** Parameter는 자동으로 처리되기 때문에 작성하지 않는다
		ResultType은 Configuration.xml에 보면 Alias로 처리했다 반드시 확인
		 ㄴ DTO는 getter/setter가 있어야 한다
	** 쿼리는 대문자로 작성 / 입력변수(바인딩)은 소문자
 -->
 	<select id="select02" resultType="JobsDto">
 		SELECT JOB_ID, JOB_TITLE, MIN_SALARY, MAX_SALARY
 		FROM JOBS
 		WHERE JOB_ID = #{job_id}
 	</select>
 	
 <!--  
 	JOB_ID <=> setJob_id, getJob_id
 	컬럼명이 생성했던 DTO의 메소드 명과 다른 경우가 있다
 	ResultMap을 선언해서 컬럼명을 DTO와 매핑시켜 준다
  -->
  <select id ="select03" resultMap="JobsToMap">
  	SELECT JOB_ID JOBID,
  			JOB_TITLE JOBTITLE,
  			MIN_SALARY MINSALARY,
  			MAX_SALARY MAXSALARY
  	FROM JOBS
  	WHERE JOB_ID = #{job_id}
  </select>
  
  <!-- 
  	resultType을 기본타입/DTO 객체가 아닌 java.uil.Map을 통해서 반환하겠다
  	목적 : DTO를 사용하지 않고 결과를 응답할때 <=> JSON형태가 유사하기 때문에 쉽게 화면에서 처리
  	** <include> 반복되는 쿼리를 미리 선언해서 변수처럼 사용
   -->
   <select id="select04" resultType="java.util.Map">
   	<include refid="allColumn"/>
   	WHERE JOB_ID = #{job_id}
   </select>
   
<!-- 
	MyBatis에서는 여러개의 Argument를 사용할 수 없다. 즉, 단일의 객체만 가능
	DTO, Map의 형태가 사용이 가능하다
	DTO에서는 getter 메소드를 통해서 값을 전달받게 된다
	Map은 key를 통해서 값을 전달받게 된다
 -->
 <select id="select05" parameterType="JobsDto" resultType="JobsDto">
 	<include refid="allColumn"/> 
 	WHERE JOB_ID = #{job_id}  JobsDto -> getJob_id()
 	AND JOB_TITLE = #{job_title} JobsDto -> getJob_title
 </select>
 
 <!-- 
 	selectList()는 실행하면 List의 객체로 반환되고
 	결과는 List의 add하여 Object로 생성된다
 	 ㄴ 쿼리의 결과가 없으면 size()가 0이 된다 => Null이 없다
  -->
 
 <select id="select06" resultType="JobsDto">
 	<include refid="allColumn"/> 
 	WHERE 1 != 1
 </select>
 
 <!-- 
 	ParameterType을 java.util.Map으로 사용한다
 	1) 쿼리를 실행하기 위해서 여러개의 값을 전달받아야 할 때
 	2) 1과 같은 상황인데 여러개를 담을 수 있는 DTO 객체가 없을때
 	3) Map {"key", value} => 반드시 key의 값으로 Mapping을 해줘야 한다
 	ex) Map<String, Object> map = new HashMap<String, Object>();
 		map.put("id", "IT_PROG")
 		
 		SELECT * FROM JOBS WHERE JOB_ID = #{id}
  -->
  
  <select id ="select07" parameterType="java.util.Map" resultType="JobsDto">
  	<include refid="allColumn"/> 
  	WHERE JOB_ID = #{id} AND JOB_TITLE = #{title}
  </select>
  
  <!-- 
  	CDATA 처리 HTML이나 혹은 javascript에서 문자열 처리 할 때 많이 보이게 되는 문법
  	XML(mapper 쿼리문) -> 환경xml(config xml 환경) -> xml 파일 IO읽어서 -> 값 -> SqlSessionFactory Argument로 사용함  
  	
  	Markup Language : 열고 닫음이 있는 언어 DTD
  	<select>SQL문</select> => String select = "SQL문";
  	문제점 : 
  		최저 급여가 10000 이하인 인원을 조회
  		<select>
  			SELECT * FROM JOBS WHERE MIN_SALARY < '10000' <=의 < 문자는 Markup Language의 문법이라고 인식
  		</select>
  	해결방법 : < 문법을 markup language가 아닌 문자열로 인식시킨다 CDATA 문법
   -->
   <select id="select08" resultType="JobsDto">
   	<include refid="allColumn"/> 
   	<![CDATA[WHERE MIN_SALARY < #{sal}]]> 
   
   </select>
	
</mapper>





