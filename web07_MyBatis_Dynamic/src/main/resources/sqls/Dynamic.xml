<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.min.edu.model.DynamicDaoImpl">

	<!-- TODO 020 공통으로 쿼리를 위한 sql작성 -->
	<sql id="selAll">
		SELECT j.JOB_ID , j.JOB_TITLE , j.MIN_SALARY , j.MAX_SALARY
		FROM JOBS j
	</sql>

	<!-- if를 통해서 조건판달을 하여 여러개의 쿼리를 선택적으로 실행 시나리오 : 조회 값이 있다면 단일 조회, 없다면 전체조회 -->

	<select id="getJobIf" parameterType="java.util.Map"
		resultType="JobsVo">
		<include refid="selAll" />
		<where> <!-- 하위의 if의 조건이 맞다면 자동 생성되는 where 태그 -->
			<if test="job_id != null">
				JOB_ID = #{job_id}
			</if>
		</where>
	</select>

	<!-- Iterator를 통해서 쿼리문의 IN절을 생성한다 값이 3개 값1, 값2, 값3 => IN('값1', '값2', '값3') 
		IN 작성( 열림, 마지막에 닫힘) 입력되는 Parameter JCF(java collection framwork) (List,Map<String, 
		Object>) -->
	<select id="getJobList" parameterType="java.util.List"
		resultType="JobsVo">
		<include refid="selAll" />
		WHERE JOB_ID IN
		<foreach collection="list" item="id" open="(" close=")">
			#{id}
		</foreach>
	</select>

	<!-- Iterator의 값을 Map으로 Parameter를 받는다 Map<String,String[]> 혹은 Map<String,List<String>> 
		사용이 가능하다 collection="ids" Map 객체의 키값으로 작성해 줘야한다 **** List의 경우는 collection="list" 
		하고 Map의 경우는 collection="키명"을 사용한다 -->

	<select id="getJobMap" parameterType="java.util.Map"
		resultType="JobsVo">
		<include refid="selAll" />
		WHERE JOB_ID IN
		<foreach collection="ids" item="id" open="(" close=")">
			#{id}
		</foreach>
	</select>

	<!-- choose문은 선택문, 조건문 when 절에서 상위부터 조건을 판단하여 선택된 한개만으로 만들어짐 -->
	<select id="getJobChoose" resultType="JobsVo">
		<include refid="selAll" />
		<where>
			<choose>
				<when test="job_id != null">
					JOB_ID =#{job_id}
				</when>
				<when test="job_title != null">
					JOB_TITLE =#{job_title}
				</when>
				<otherwise>
				</otherwise>
			</choose>
		</where>
	</select>

	<!-- trim을 통해서 사용되는 쿼리를 오버라이드하여 제거하거나 추가할 수 있다 
		WHERE JOB_ID='a' AND JOB_TITLE='b'  : 2개의 값이 있을 때 
		WHERE JOB_ID='a' 					: JOB_ID만 있을 때 
		WHERE JOB_TITLE='b' 				: JOB_TITLE만 있을 때 -->

	<select id="getJobTrim" resultType="JobsVo">
		<include refid="selAll"/>
		<trim prefix="WHERE" prefixOverrides="AND|OR">
			<if test="job_id != null">
				JOB_ID = #{job_id}
			</if>
			<if test="job_title != null">
				AND JOB_TITLE =#{job_title}
			</if>
		</trim>
	</select>
	
	<!-- 
		update에서 사용되는 set을 통한 , 삭제를 하여 여러개의 set을 작성한다\
		<set>은 <trim suffixOverride=",">를 통해서도 작성이 가능하다
	 -->
	 <update id="jobUpdateSet">
	 	UPDATE JOBS
	 		<set>
	 			<if test="job_id != null">
	 				JOB_ID = #{job_id},
	 			</if>
	 			<if test="job_title != null">
	 				JOB_TITLE = #{job_title}
	 			</if>
	 		</set>
	 	 WHERE JOB_ID='AD_PRES'
	 </update>
	 
	 <update id="jobUpdateSetTrim">
	  UPDATE JOBS
	  <trim prefix="set" suffixOverrides=",">
	     <if test="job_id != null">
	       JOB_ID = #{job_id},
	    </if>
	    <if test="job_title != null">
	       JOB_TITLE = #{job_title}
	    </if>
	  </trim>
	  WHERE JOB_ID='AD_PRES' 
	</update>


	<!-- 
		주문 실시간의 주문이 아닌 특정한 주기로 주문의 내역을 입력해줘야 한다
		같은 주문의 형식이 여러개가 insert되어야 한다
	 -->
	 
	 <insert id="insertUserInfoList" parameterType="java.util.List">
	 	<selectKey keyProperty="seq" resultType="java.lang.Integer" order="BEFORE">
	 		SELECT MAX(SEQ)+1 SEQ FROM USERINFO
	 	</selectKey>
	 	
	 	INSERT INTO USERINFO (SEQ, NAME, TEL, CREATEAT, UNIV_ID)
	 	<foreach collection="list" item="vo" separator=" UNION ALL " index="index">
	 		SELECT #{seq} + #{index}, #{vo.name}, #{vo.tel}, SYSDATE, 'U01' FROM DUAL
	 	</foreach>
	 </insert>



</mapper>